# Docker/isaac/nvidia.env.example
#
# Template for NGC / NVIDIA credentials. DO NOT commit your real key.
# Copy this to `nvidia.env` (gitignored at the repo root via .env.local pattern) and fill in.
#
# An NGC API key is required to pull `nvcr.io/nvidia/isaac-sim:5.1.0`. Get one at:
#   https://ngc.nvidia.com  →  Setup  →  Generate API Key
#
# To log Docker in once (recommended; no env file needed afterwards):
#   echo "$NGC_API_KEY" | docker login nvcr.io -u '$oauthtoken' --password-stdin
#
# After `docker login` succeeds, the credentials are stored in ~/.docker/config.json
# (or via the system credential helper) and you do NOT need to source this file.

NGC_API_KEY=__paste_your_NGC_API_key_here__

# Optional: override the Isaac Sim image tag (must exist on nvcr.io).
ISAAC_SIM_VERSION=5.1.0
