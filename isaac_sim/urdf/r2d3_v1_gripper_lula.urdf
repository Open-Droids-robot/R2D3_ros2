  </joint>
  <link name="r_wrist_camera_infra2_optical_frame"><inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="0.001"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial></link>
  <!-- camera color joints and links -->
  <joint name="r_wrist_camera_color_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0.015 0"/>
    <parent link="r_wrist_camera_link"/>
    <child link="r_wrist_camera_color_frame"/>
  </joint>
  <link name="r_wrist_camera_color_frame"><inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="0.001"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial></link>
  <joint name="r_wrist_camera_color_optical_joint" type="fixed">
    <origin rpy="-1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0"/>
    <parent link="r_wrist_camera_color_frame"/>
    <child link="r_wrist_camera_color_optical_frame"/>
  </joint>
  <link name="r_wrist_camera_color_optical_frame"><inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="0.001"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial></link>
  <!--
      Finger geometry (simple boxes):
        - X axis (out of palm) : 0.05 m   length of the finger
        - Y axis (closing axis): 0.01 m   finger thickness
        - Z axis (vertical)    : 0.02 m   finger height

      Mass per finger: 50 g. Inertia computed for a uniform-density box:
        ixx = m * (ly² + lz²) / 12 = 0.05 * (0.0001 + 0.0004) / 12 ≈ 2.08e-6
        iyy = m * (lx² + lz²) / 12 = 0.05 * (0.0025 + 0.0004) / 12 ≈ 1.21e-5
        izz = m * (lx² + ly²) / 12 = 0.05 * (0.0025 + 0.0001) / 12 ≈ 1.08e-5
    -->
  <!-- LEFT finger (the driven side; moves in +Y as drive increases) -->
  <link name="l_finger_left">
    <inertial>
      <origin rpy="0 0 0" xyz="0.025 0.005 0"/>
      <mass value="0.05"/>
      <inertia ixx="2.08e-6" ixy="0" ixz="0" iyy="1.21e-5" iyz="0" izz="1.08e-5"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0.025 0.005 0"/>
      <geometry>
        <box size="0.05 0.01 0.02"/>
      </geometry>
      <material name="l_finger_left_material">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.025 0.005 0"/>
      <geometry>
        <box size="0.05 0.01 0.02"/>
      </geometry>
    </collision>
  </link>
  <!-- RIGHT finger (mirrors LEFT across the Y=0 plane; moves in -Y) -->
  <link name="l_finger_right">
    <inertial>
      <origin rpy="0 0 0" xyz="0.025 -0.005 0"/>
      <mass value="0.05"/>
      <inertia ixx="2.08e-6" ixy="0" ixz="0" iyy="1.21e-5" iyz="0" izz="1.08e-5"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0.025 -0.005 0"/>
      <geometry>
        <box size="0.05 0.01 0.02"/>
      </geometry>
      <material name="l_finger_right_material">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.025 -0.005 0"/>
      <geometry>
        <box size="0.05 0.01 0.02"/>
      </geometry>
    </collision>
  </link>
  <!--
      Driving joint. Axis +Y in the parent (hand_base_link) frame. Joint
      value = distance LEFT finger has moved in +Y from the palm center.
      Range [0, 0.035] m, velocity ≤ 0.05 m/s, effort ≈ 100 N.
    -->
  <joint name="l_finger_drive" type="prismatic">
    <parent link="l_hand_link"/>
    <child link="l_finger_left"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="0.0" upper="0.035" velocity="0.05"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <!--
      Mimic joint. Authored as a plain prismatic (no <mimic> element) so the
      URDF→USD converter doesn't apply NewtonMimicAPI — the default PhysX
      solver in Isaac Sim 6.0 doesn't honor it and the articulation goes NaN.
      Symmetric closure is enforced in robot.set_finger(): both finger_drive
      and finger_mimic are commanded to the same scalar.
    -->
  <joint name="l_finger_mimic" type="prismatic">
    <parent link="l_hand_link"/>
    <child link="l_finger_right"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit effort="100" lower="0.0" upper="0.035" velocity="0.05"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <!--
      Finger geometry (simple boxes):
        - X axis (out of palm) : 0.05 m   length of the finger
        - Y axis (closing axis): 0.01 m   finger thickness
        - Z axis (vertical)    : 0.02 m   finger height

      Mass per finger: 50 g. Inertia computed for a uniform-density box:
        ixx = m * (ly² + lz²) / 12 = 0.05 * (0.0001 + 0.0004) / 12 ≈ 2.08e-6
        iyy = m * (lx² + lz²) / 12 = 0.05 * (0.0025 + 0.0004) / 12 ≈ 1.21e-5
        izz = m * (lx² + ly²) / 12 = 0.05 * (0.0025 + 0.0001) / 12 ≈ 1.08e-5
    -->
  <!-- LEFT finger (the driven side; moves in +Y as drive increases) -->
  <link name="r_finger_left">
    <inertial>
      <origin rpy="0 0 0" xyz="0.025 0.005 0"/>
      <mass value="0.05"/>
      <inertia ixx="2.08e-6" ixy="0" ixz="0" iyy="1.21e-5" iyz="0" izz="1.08e-5"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0.025 0.005 0"/>
      <geometry>
        <box size="0.05 0.01 0.02"/>
      </geometry>
      <material name="r_finger_left_material">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.025 0.005 0"/>
      <geometry>
        <box size="0.05 0.01 0.02"/>
      </geometry>
    </collision>
  </link>
  <!-- RIGHT finger (mirrors LEFT across the Y=0 plane; moves in -Y) -->
  <link name="r_finger_right">
    <inertial>
      <origin rpy="0 0 0" xyz="0.025 -0.005 0"/>
      <mass value="0.05"/>
      <inertia ixx="2.08e-6" ixy="0" ixz="0" iyy="1.21e-5" iyz="0" izz="1.08e-5"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0.025 -0.005 0"/>
      <geometry>
        <box size="0.05 0.01 0.02"/>
      </geometry>
      <material name="r_finger_right_material">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.025 -0.005 0"/>
      <geometry>
        <box size="0.05 0.01 0.02"/>
      </geometry>
    </collision>
  </link>
  <!--
      Driving joint. Axis +Y in the parent (hand_base_link) frame. Joint
      value = distance LEFT finger has moved in +Y from the palm center.
      Range [0, 0.035] m, velocity ≤ 0.05 m/s, effort ≈ 100 N.
    -->
  <joint name="r_finger_drive" type="prismatic">
    <parent link="r_hand"/>
    <child link="r_finger_left"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="0.0" upper="0.035" velocity="0.05"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <!--
      Mimic joint. Authored as a plain prismatic (no <mimic> element) so the
      URDF→USD converter doesn't apply NewtonMimicAPI — the default PhysX
      solver in Isaac Sim 6.0 doesn't honor it and the articulation goes NaN.
      Symmetric closure is enforced in robot.set_finger(): both finger_drive
      and finger_mimic are commanded to the same scalar.
    -->
  <joint name="r_finger_mimic" type="prismatic">
    <parent link="r_hand"/>
    <child link="r_finger_right"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit effort="100" lower="0.0" upper="0.035" velocity="0.05"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
</robot>
