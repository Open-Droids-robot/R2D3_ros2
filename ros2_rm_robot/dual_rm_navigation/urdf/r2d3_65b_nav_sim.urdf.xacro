<?xml version="1.0"?>
<!--
  R2D3 65b Navigation Simulation URDF for Gazebo Harmonic (Gz Sim 8)

  This xacro:
    1. Adds base_footprint at ground level (required for Nav2)
    2. Includes the full 65b robot description
    3. Adds simulated LiDAR (gpu_lidar) and IMU sensors
    4. Defines ros2_control with velocity-command on drive wheels (for diff_drive_controller)
       and position-command on arm/platform joints
    5. Configures gz_ros2_control plugin for Gz Sim
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="r2d3_65b_nav_sim">

   
    <link name="base_footprint"/>

    <joint name="base_footprint_to_base" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link_underpan"/>
        <origin xyz="0 0 0.233" rpy="0 0 0"/>
    </joint>

    
    <xacro:include filename="$(find dual_rm_65b_description)/urdf/dual_rm_65b_description.urdf.xacro"/>

    
    <link name="lidar_link">
        <visual>
            <geometry>
                <cylinder length="0.05" radius="0.03"/>
            </geometry>
            <material name="lidar_black">
                <color rgba="0.1 0.1 0.1 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.05" radius="0.03"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>

    <joint name="lidar_joint" type="fixed">
        <parent link="body_base_link"/>
        <child link="lidar_link"/>
        
        <origin xyz="0.0 0.0 0.75" rpy="0 0 0"/>
    </joint>

    <link name="imu_link">
        <inertial>
            <mass value="0.01"/>
            <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
        </inertial>
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link_underpan"/>
        <child link="imu_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

   

    <gazebo reference="base_link_underpan">
        <self_collide>false</self_collide>
    </gazebo>
    <gazebo reference="body_base_link">
        <self_collide>false</self_collide>
    </gazebo>
    <gazebo reference="platform_base_link">
        <self_collide>false</self_collide>
        <gravity>false</gravity>
    </gazebo>

    <gazebo reference="link_right_wheel">
        <self_collide>false</self_collide>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
    </gazebo>
    <gazebo reference="link_left_wheel">
        <self_collide>false</self_collide>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
    </gazebo>

    <gazebo reference="link_swivel_wheel_1_1">
        <self_collide>false</self_collide>
        <mu1>0.05</mu1>
        <mu2>0.05</mu2>
    </gazebo>
    <gazebo reference="link_swivel_wheel_1_2">
        <self_collide>false</self_collide>
        <mu1>0.05</mu1>
        <mu2>0.05</mu2>
    </gazebo>
    <gazebo reference="link_swivel_wheel_2_1">
        <self_collide>false</self_collide>
        <mu1>0.05</mu1>
        <mu2>0.05</mu2>
    </gazebo>
    <gazebo reference="link_swivel_wheel_2_2">
        <self_collide>false</self_collide>
        <mu1>0.05</mu1>
        <mu2>0.05</mu2>
    </gazebo>
    <gazebo reference="link_swivel_wheel_3_1">
        <self_collide>false</self_collide>
        <mu1>0.05</mu1>
        <mu2>0.05</mu2>
    </gazebo>
    <gazebo reference="link_swivel_wheel_3_2">
        <self_collide>false</self_collide>
        <mu1>0.05</mu1>
        <mu2>0.05</mu2>
    </gazebo>
    <gazebo reference="link_swivel_wheel_4_1">
        <self_collide>false</self_collide>
        <mu1>0.05</mu1>
        <mu2>0.05</mu2>
    </gazebo>
    <gazebo reference="link_swivel_wheel_4_2">
        <self_collide>false</self_collide>
        <mu1>0.05</mu1>
        <mu2>0.05</mu2>
    </gazebo>

    <gazebo reference="r_link1"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="r_link2"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="r_link3"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="r_link4"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="r_link5"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="r_link6"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="l_link1"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="l_link2"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="l_link3"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="l_link4"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="l_link5"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="l_link6"><self_collide>false</self_collide><gravity>false</gravity></gazebo>

    <gazebo reference="head_link1"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="head_link2"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="camera_link"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="l_base_link1"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="r_base_link1"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="r_hand_base_link"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="l_hand_base_link"><self_collide>false</self_collide><gravity>false</gravity></gazebo>

    <gazebo reference="lidar_link"><self_collide>false</self_collide><gravity>false</gravity></gazebo>
    <gazebo reference="imu_link"><self_collide>false</self_collide><gravity>false</gravity></gazebo>

 
    <!-- 360° LiDAR (gpu_lidar) -->
    <gazebo reference="lidar_link">
        <sensor name="lidar" type="gpu_lidar">
            <always_on>true</always_on>
            <visualize>true</visualize>
            <update_rate>10</update_rate>
            <topic>scan</topic>
            <gz_frame_id>lidar_link</gz_frame_id>
            <ray>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1.0</resolution>
                        <min_angle>0.0</min_angle>
                        <max_angle>6.28318</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.12</min>
                    <max>12.0</max>
                    <resolution>0.015</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </ray>
        </sensor>
    </gazebo>

    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>true</always_on>
            <update_rate>100</update_rate>
            <topic>imu</topic>
            <gz_frame_id>imu_link</gz_frame_id>
        </sensor>
    </gazebo>

    
    <gazebo>
        <static>false</static>
        <self_collide>false</self_collide>
    </gazebo>

    <ros2_control name="GazeboSimSystem" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>

        <joint name="joint_left_wheel">
            <command_interface name="velocity">
                <param name="min">-10</param>
                <param name="max">10</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint_right_wheel">
            <command_interface name="velocity">
                <param name="min">-10</param>
                <param name="max">10</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <!-- === Left arm: 6 joints, position command === -->
        <joint name="l_joint1">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="l_joint2">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="l_joint3">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="l_joint4">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="l_joint5">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="l_joint6">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>

        <!-- === Right arm: 6 joints, position command === -->
        <joint name="r_joint1">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="r_joint2">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="r_joint3">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="r_joint4">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="r_joint5">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="r_joint6">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>

        <!-- === Platform lift: position command === -->
        <joint name="platform_joint">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>

        <!-- === Head joints: position command === -->
        <joint name="head_joint1">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="head_joint2">
            <command_interface name="position"/>
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>

        <!-- === Swivel / caster wheels: state only (passive, physics-driven) === -->
        <joint name="joint_swivel_wheel_1_1">
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint_swivel_wheel_1_2">
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint_swivel_wheel_2_1">
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint_swivel_wheel_2_2">
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint_swivel_wheel_3_1">
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint_swivel_wheel_3_2">
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint_swivel_wheel_4_1">
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint_swivel_wheel_4_2">
            <state_interface name="position"><param name="initial_value">0</param></state_interface>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

   
    <gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(find dual_rm_navigation)/config/controllers_65b.yaml</parameters>
            <robot_param>robot_description</robot_param>
            <robot_param_node>robot_state_publisher</robot_param_node>
        </plugin>
    </gazebo>

</robot>
