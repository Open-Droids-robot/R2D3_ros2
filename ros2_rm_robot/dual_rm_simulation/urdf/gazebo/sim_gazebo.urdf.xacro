<?xml version="1.0"?>
<!--
  Gazebo Sim physics properties for R2D3 navigation simulation.

  Sets self_collide, friction (mu1/mu2), and gravity overrides for every
  link that needs them.  Parameterised by arm_dof so the same file works
  for both the 65b (6-DOF arms) and 75b (7-DOF arms) variants.

  Usage:
    <xacro:include filename=".../gazebo/sim_gazebo.urdf.xacro"/>
    <xacro:sim_gazebo_properties arm_dof="6"/>   ← 65b
    <xacro:sim_gazebo_properties arm_dof="7"/>   ← 75b
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- ── Helper: mark a link as no-gravity, no-self-collide ── -->
    <xacro:macro name="_gz_no_gravity" params="link_name">
        <gazebo reference="${link_name}">
            <self_collide>false</self_collide>
            <gravity>false</gravity>
        </gazebo>
    </xacro:macro>

    <!-- ── Helper: caster wheel friction ─────────────────────── -->
    <xacro:macro name="_gz_caster" params="link_name">
        <gazebo reference="${link_name}">
            <self_collide>false</self_collide>
            <mu1>0.05</mu1>
            <mu2>0.05</mu2>
        </gazebo>
    </xacro:macro>

    <!-- ============================================================
         Main macro
         ============================================================ -->
    <xacro:macro name="sim_gazebo_properties" params="arm_dof">

        <!-- ── Robot-level ───────────────────────────────────── -->
        <gazebo>
            <static>false</static>
            <self_collide>false</self_collide>
        </gazebo>

        <!-- ── Chassis & body ────────────────────────────────── -->
        <gazebo reference="base_link_underpan">
            <self_collide>false</self_collide>
        </gazebo>
        <gazebo reference="body_base_link">
            <self_collide>false</self_collide>
        </gazebo>
        <gazebo reference="platform_base_link">
            <self_collide>false</self_collide>
            <gravity>false</gravity>
        </gazebo>

        <!-- ── Drive wheels (high friction) ──────────────────── -->
        <gazebo reference="link_right_wheel">
            <self_collide>false</self_collide>
            <mu1>1.0</mu1>
            <mu2>1.0</mu2>
        </gazebo>
        <gazebo reference="link_left_wheel">
            <self_collide>false</self_collide>
            <mu1>1.0</mu1>
            <mu2>1.0</mu2>
        </gazebo>

        <!-- ── Caster / swivel wheels (low friction) ─────────── -->
        <xacro:_gz_caster link_name="link_swivel_wheel_1_1"/>
        <xacro:_gz_caster link_name="link_swivel_wheel_1_2"/>
        <xacro:_gz_caster link_name="link_swivel_wheel_2_1"/>
        <xacro:_gz_caster link_name="link_swivel_wheel_2_2"/>
        <xacro:_gz_caster link_name="link_swivel_wheel_3_1"/>
        <xacro:_gz_caster link_name="link_swivel_wheel_3_2"/>
        <xacro:_gz_caster link_name="link_swivel_wheel_4_1"/>
        <xacro:_gz_caster link_name="link_swivel_wheel_4_2"/>

        <!-- ── Arm links (no gravity) ────────────────────────── -->
        <!-- Common to both 65b and 75b: links 1-6 -->
        <xacro:_gz_no_gravity link_name="r_link1"/>
        <xacro:_gz_no_gravity link_name="r_link2"/>
        <xacro:_gz_no_gravity link_name="r_link3"/>
        <xacro:_gz_no_gravity link_name="r_link4"/>
        <xacro:_gz_no_gravity link_name="r_link5"/>
        <xacro:_gz_no_gravity link_name="r_link6"/>
        <xacro:_gz_no_gravity link_name="l_link1"/>
        <xacro:_gz_no_gravity link_name="l_link2"/>
        <xacro:_gz_no_gravity link_name="l_link3"/>
        <xacro:_gz_no_gravity link_name="l_link4"/>
        <xacro:_gz_no_gravity link_name="l_link5"/>
        <xacro:_gz_no_gravity link_name="l_link6"/>

        <!-- 75b only: link7 -->
        <xacro:if value="${arm_dof == 7}">
            <xacro:_gz_no_gravity link_name="r_link7"/>
            <xacro:_gz_no_gravity link_name="l_link7"/>
        </xacro:if>

        <!-- ── Head, camera, hand base links ─────────────────── -->
        <xacro:_gz_no_gravity link_name="head_link1"/>
        <xacro:_gz_no_gravity link_name="head_link2"/>
        <xacro:_gz_no_gravity link_name="camera_link"/>
        <xacro:_gz_no_gravity link_name="l_base_link1"/>
        <xacro:_gz_no_gravity link_name="r_base_link1"/>
        <xacro:_gz_no_gravity link_name="r_hand_base_link"/>
        <xacro:_gz_no_gravity link_name="l_hand_base_link"/>

    </xacro:macro>

</robot>
