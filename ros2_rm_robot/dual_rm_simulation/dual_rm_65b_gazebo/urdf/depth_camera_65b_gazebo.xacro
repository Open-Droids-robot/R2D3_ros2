<?xml version="1.0"?>
<robot name="depth_camera_gazebo" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <gazebo reference="camera_link">
        <material>Gazebo/Black</material>

        <sensor name="depth_camera" type="depth">
            <!-- Rotate sensor to match optical frame -->
            <pose>0 0 0 ${-pi/2} 0 ${-pi/2}</pose>
            <visualize>true</visualize>
            <update_rate>30.0</update_rate>

            <camera>
                <horizontal_fov>1.518</horizontal_fov>
                
                <image>
                    <format>B8G8R8</format>
                    <width>1280</width>
                    <height>720</height>
                </image>

                <clip>
                    <near>0.28</near>
                    <far>3.0</far>
                </clip>
            </camera>

            <plugin name="depth_camera_controller" filename="libgazebo_ros_camera.so">
                <frame_name>camera_link_optical</frame_name>
                <hack_baseline>0.07</hack_baseline>
                <min_depth>0.28</min_depth>
                <max_depth>3.0</max_depth>
            </plugin>
        </sensor>

        <!-- IMU Sensor (shares same coordinate system as depth sensor) -->
        <sensor name="camera_imu" type="imu">
            <pose>0 0 0 ${-pi/2} 0 ${-pi/2}</pose>  <!-- Same rotation as camera -->
            <always_on>true</always_on>
            <update_rate>200</update_rate>
            <visualize>false</visualize>
            
            <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
                <ros>
                    <namespace></namespace>
                    <remapping>~/out:=camera/imu</remapping>
                </ros>
                <initial_orientation_as_reference>false</initial_orientation_as_reference>
                <frame_name>camera_link_optical</frame_name>  <!-- Use optical frame -->
            </plugin>
            
            <imu>
                <angular_velocity>
                    <x>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>2e-4</stddev>
                            <bias_mean>0.0000075</bias_mean>
                            <bias_stddev>0.0000008</bias_stddev>
                        </noise>
                    </x>
                    <y>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>2e-4</stddev>
                            <bias_mean>0.0000075</bias_mean>
                            <bias_stddev>0.0000008</bias_stddev>
                        </noise>
                    </y>
                    <z>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>2e-4</stddev>
                            <bias_mean>0.0000075</bias_mean>
                            <bias_stddev>0.0000008</bias_stddev>
                        </noise>
                    </z>
                </angular_velocity>
                <linear_acceleration>
                    <x>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>1.7e-2</stddev>
                            <bias_mean>0.1</bias_mean>
                            <bias_stddev>0.001</bias_stddev>
                        </noise>
                    </x>
                    <y>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>1.7e-2</stddev>
                            <bias_mean>0.1</bias_mean>
                            <bias_stddev>0.001</bias_stddev>
                        </noise>
                    </y>
                    <z>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>1.7e-2</stddev>
                            <bias_mean>0.1</bias_mean>
                            <bias_stddev>0.001</bias_stddev>
                        </noise>
                    </z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>
</robot>