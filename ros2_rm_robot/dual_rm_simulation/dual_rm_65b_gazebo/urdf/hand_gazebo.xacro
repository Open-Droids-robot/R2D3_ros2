      <joint>right_thumb_distal_joint</joint>
      <mimicJoint>right_thumb_proximal_pitch_joint</mimicJoint>
      <multiplier>0.667</multiplier>
      <offset>0.0</offset>
      <sensitiveness>0.0</sensitiveness>
      <maxEffort>1.0</maxEffort>
      <hasPID/>
      <p>5.0</p>
      <i>0.0</i>
      <d>0.5</d>
      
      <!-- Right Index Intermediate Joint -->
      <!-- Mimics: right_index_proximal_joint -->
      <!-- Multiplier: 1.06399, Offset: -0.04545 -->
      <joint>right_index_intermediate_joint</joint>
      <mimicJoint>right_index_proximal_joint</mimicJoint>
      <multiplier>1.06399</multiplier>
      <offset>-0.04545</offset>
      <sensitiveness>0.0</sensitiveness>
      <maxEffort>1.0</maxEffort>
      <hasPID/>
      <p>5.0</p>
      <i>0.0</i>
      <d>0.5</d>
      
      <!-- Right Middle Intermediate Joint -->
      <!-- Mimics: right_middle_proximal_joint -->
      <!-- Multiplier: 1.06399, Offset: -0.04545 -->
      <joint>right_middle_intermediate_joint</joint>
      <mimicJoint>right_middle_proximal_joint</mimicJoint>
      <multiplier>1.06399</multiplier>
      <offset>-0.04545</offset>
      <sensitiveness>0.0</sensitiveness>
      <maxEffort>1.0</maxEffort>
      <hasPID/>
      <p>5.0</p>
      <i>0.0</i>
      <d>0.5</d>
      
      <!-- Right Ring Intermediate Joint -->
      <!-- Mimics: right_ring_proximal_joint -->
      <!-- Multiplier: 1.06399, Offset: -0.04545 -->
      <joint>right_ring_intermediate_joint</joint>
      <mimicJoint>right_ring_proximal_joint</mimicJoint>
      <multiplier>1.06399</multiplier>
      <offset>-0.04545</offset>
      <sensitiveness>0.0</sensitiveness>
      <maxEffort>1.0</maxEffort>
      <hasPID/>
      <p>5.0</p>
      <i>0.0</i>
      <d>0.5</d>
      
      <!-- Right Pinky Intermediate Joint -->
      <!-- Mimics: right_pinky_proximal_joint -->
      <!-- Multiplier: 1.06399, Offset: -0.04545 -->
      <joint>right_pinky_intermediate_joint</joint>
      <mimicJoint>right_pinky_proximal_joint</mimicJoint>
      <multiplier>1.06399</multiplier>
      <offset>-0.04545</offset>
      <sensitiveness>0.0</sensitiveness>
      <maxEffort>1.0</maxEffort>
