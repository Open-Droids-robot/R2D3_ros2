    </gazebo>
    
   <gazebo reference="link_left_wheel">
        <mu1>0.2</mu1>
        <mu2>0.2</mu2>
        <!-- <kp>1000000.0</kp>
        <kd>100.0</kd>
        <minDepth>0.001</minDepth>
        <maxVel>1.0</maxVel> -->
        <material>Gazebo/DarkGrey</material>   
