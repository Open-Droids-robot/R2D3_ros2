<?xml version="1.0"?>
<!--
  Named URDF materials (colours) for the R2D3 robot.

  Defining colours here avoids magic RGBA values scattered across
  component files and gives every part a readable material name.

  Usage:
    <xacro:include filename="$(find dual_rm_description)/urdf/materials/colors.urdf.xacro"/>

    Then reference in <visual>:
      <material name="r2d3/body"/>
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Robot body / chassis / arms — light lavender-grey -->
    <material name="r2d3/body">
        <color rgba="0.79216 0.81961 0.93333 1.0"/>
    </material>

    <!-- Grippers / hands — neutral silver -->
    <material name="r2d3/hand">
        <color rgba="0.75294 0.75294 0.75294 1.0"/>
    </material>

    <!-- Drive wheels — dark rubber -->
    <material name="r2d3/wheel">
        <color rgba="0.2 0.2 0.2 1.0"/>
    </material>

    <!-- Sensors (LiDAR, camera) — black -->
    <material name="r2d3/sensor">
        <color rgba="0.1 0.1 0.1 1.0"/>
    </material>

</robot>
