  <xacro:woosh_agv_transmission joint_name="joint_swivel_wheel_1_1" />
  <xacro:woosh_agv_transmission joint_name="joint_swivel_wheel_1_2" />
  <xacro:woosh_agv_transmission joint_name="joint_swivel_wheel_2_1" />
  <xacro:woosh_agv_transmission joint_name="joint_swivel_wheel_2_2" />
  <xacro:woosh_agv_transmission joint_name="joint_swivel_wheel_3_1" />
  <xacro:woosh_agv_transmission joint_name="joint_swivel_wheel_3_2" />
