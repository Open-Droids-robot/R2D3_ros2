<?xml version="1.0"?>
<!--
  R2D3 65b Robot Description — main xacro entry point.

  Assembles the full robot from modular sub-components:
    agv/            — AGV chassis, drive wheels, caster wheels
    body/           — Torso, head, camera, platform lift
    left_arm/       — Left 6-DOF arm + gripper
    right_arm/      — Right 6-DOF arm + gripper
    joints/         — Cross-component joints (body↔arms, arms↔hands)
    materials/      — Named URDF colour definitions
    transmissions/  — Legacy ROS1 transmission tags (kept for compatibility)
-->
<robot name="dual_rm_65b_description" xmlns:xacro="http://ros.org/wiki/xacro">

    <!-- ── Materials ─────────────────────────────────────────── -->
    <xacro:include filename="$(find dual_rm_65b_description)/urdf/materials/colors.urdf.xacro"/>

    <!-- ── AGV chassis (wheels, casters) ─────────────────────── -->
    <xacro:include filename="$(find dual_rm_65b_description)/urdf/agv/woosh_agv.urdf.xacro"/>

    <!-- ── Body, head, camera, platform lift ─────────────────── -->
    <xacro:include filename="$(find dual_rm_65b_description)/urdf/body/body_head_platform.urdf.xacro"/>

    <!-- ── Left arm (6-DOF) + gripper ────────────────────────── -->
    <xacro:include filename="$(find dual_rm_65b_description)/urdf/left_arm/rm65_b_v_left.urdf.xacro"/>
    <xacro:include filename="$(find dual_rm_65b_description)/urdf/left_arm/left_hand.urdf.xacro"/>

    <!-- ── Right arm (6-DOF) + gripper ───────────────────────── -->
    <xacro:include filename="$(find dual_rm_65b_description)/urdf/right_arm/rm65_b_v_right.urdf.xacro"/>
    <xacro:include filename="$(find dual_rm_65b_description)/urdf/right_arm/right_hand.urdf.xacro"/>

    <!-- ── Cross-component joints ────────────────────────────── -->
    <xacro:include filename="$(find dual_rm_65b_description)/urdf/joints/joint.urdf.xacro"/>

    <!-- ── Transmissions (legacy ROS1, kept for compatibility) ── -->
    <xacro:include filename="$(find dual_rm_65b_description)/urdf/transmissions/rm65_b_v_left_transmission.xacro"/>
    <xacro:include filename="$(find dual_rm_65b_description)/urdf/transmissions/rm65_b_v_right_transmission.xacro"/>
    <xacro:include filename="$(find dual_rm_65b_description)/urdf/transmissions/body_head_platform_transmission.xacro"/>

</robot>
