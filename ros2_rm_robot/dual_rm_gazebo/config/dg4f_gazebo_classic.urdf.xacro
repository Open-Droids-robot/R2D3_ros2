<?xml version="1.0"?>
<!--
  dg4f_gazebo_classic.urdf.xacro
  
  Gazebo Classic wrapper for the TESOLLO DG-4F gripper.
  Attaches the gripper to the R2D3 left arm (l_hand_link).
  
  Usage: include this file in dual_rm_75b_gazebo.urdf.xacro
  
    <xacro:include filename="$(find dual_rm_gazebo)/config/dg4f_gazebo_classic.urdf.xacro"/>
    <xacro:dg4f_attach parent="l_hand_link" xyz="0 0 0.01" rpy="0 0 0"/>

  NOTE: The mimic joints (j_dg_1_outer, j_dg_1_mimic, j_dg_4_outer, j_dg_4_mimic)
  are kept as revolute joints in URDF but registered as passive in ros2_control.
  Gazebo Classic does not natively support URDF <mimic> tags — those joints will
  stay at 0. For visual correctness you can add a mimic_joint_plugin later.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="dg4f_attach" params="parent xyz rpy">

    <!-- ============================================================
         ATTACHMENT JOINT: gripper mount to arm tip
         ============================================================ -->
    <joint name="l_hand_to_dg4f" type="fixed">
      <parent link="${parent}"/>
      <child link="l_dg_mount"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <!-- ============================================================
         INCLUDE ALL DG-4F LINKS AND JOINTS
         (copy of dg4f.urdf content, robot tag removed)
         ============================================================ -->

    <!-- base -->
    <link name="l_dg_mount">
      <inertial>
        <origin xyz="6.4721E-09 2.1674E-05 0.0049997" rpy="0.0 0.0 0.0"/>
        <inertia ixx="1.0999E-05" ixy="-2.1734E-12" ixz="-1.2441E-12"
                 iyy="1.1018E-05" iyz="-4.0435E-09" izz="2.0531E-05"/>
        <mass value="0.05"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://dg_description/meshes/dg4f/l_dg_mount.dae"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://dg_description/meshes/dg4f/l_dg_mount_c.STL"/>
        </geometry>
      </collision>
    </link>

    <joint name="j_dg_base" type="fixed">
      <parent link="l_dg_mount"/>
      <child link="l_dg_base"/>
      <origin rpy="0 0 0" xyz="0 0 0.004"/>
    </joint>

    <link name="l_dg_base">
      <inertial>
        <mass value="0.451"/>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
        <inertia ixx="0.00226" ixy="0.0" ixz="0.0" iyy="0.00226" iyz="0.0" izz="0.00113"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dg_description/meshes/dg4f/DG_F_P.stl"/>
        </geometry>
        <material name="very_dark_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dg_description/meshes/dg4f/DG_F_P.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="l_dg_logo">
      <inertial>
        <mass value="0.001"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dg_description/meshes/dg4f/DG_F_P_LOGO.stl"/>
        </geometry>
        <material name="white"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dg_description/meshes/dg4f/DG_F_P_LOGO.stl"/>
        </geometry>
      </collision>
    </link>

    <joint name="j_dg_logo" type="fixed">
      <origin xyz="-0.00003 0.0 0.1481" rpy="0.0 0.0 0.0"/>
      <parent link="l_dg_base"/>
      <child link="l_dg_logo"/>
    </joint>

    <!-- ============================================================
         FINGER 1 (thumb-like, has abduction j_dg_1_inner)
         ============================================================ -->
    <link name="l_dg_1_inner">
      <inertial>
        <mass value="0.027"/>
        <origin xyz="-0.015 0 0.02" rpy="0 0 0"/>
        <inertia ixx="0.0000135" ixy="0.0" ixz="0.0" iyy="0.0000270" iyz="0.0" izz="0.0000270"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 -0.366519"/>
        <geometry><mesh filename="package://dg_description/meshes/dg4f/DG_F_L_FB_1.stl"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 -0.366519"/>
        <geometry><mesh filename="package://dg_description/meshes/dg4f/DG_F_L_FB_1.stl"/></geometry>
      </collision>
    </link>
    <joint name="j_dg_1_inner" type="revolute">
      <origin xyz="-0.00747 0.01918 0.07577" rpy="0.0 0.0 0.0"/>
      <parent link="l_dg_base"/>
      <child link="l_dg_1_inner"/>
      <axis xyz="0 0 1"/>
      <limit lower="0" upper="2.495821" effort="7.644" velocity="3.141592653589793"/>
    </joint>

    <!-- mimic outer (passive in simulation) -->
    <link name="l_dg_1_outer">
      <inertial>
        <mass value="0.046"/>
        <origin xyz="0.015 0 0.02" rpy="0 0 0"/>
        <inertia ixx="0.0000230" ixy="0.0" ixz="0.0" iyy="0.0000460" iyz="0.0" izz="0.0000460"/>
