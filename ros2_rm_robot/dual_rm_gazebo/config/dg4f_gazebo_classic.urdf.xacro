    </link>
    <joint name="j_dg_1_outer" type="revolute">
      <origin xyz="-0.00003 0.02516 0.08349" rpy="0.0 0.0 0.0"/>
      <parent link="l_dg_base"/>
      <child link="l_dg_1_outer"/>
      <axis xyz="0 0 1"/>
      <limit lower="0" upper="2.897247" effort="7.644" velocity="3.141592653589793"/>
    </joint>

    <link name="l_dg_1_1">
      <inertial>
        <mass value="0.027"/>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <inertia ixx="0.0000135" ixy="0.0" ixz="0.0" iyy="0.0000270" iyz="0.0" izz="0.0000270"/>
