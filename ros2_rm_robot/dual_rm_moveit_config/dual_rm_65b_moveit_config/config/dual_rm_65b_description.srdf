    <disable_collisions link1="right_ring_intermediate" link2="right_pinky_intermediate" reason="Default"/>

    <!-- Right non-adjacent fingers -->
    <disable_collisions link1="right_index_proximal" link2="right_ring_proximal" reason="Never"/>
    <disable_collisions link1="right_index_proximal" link2="right_pinky_proximal" reason="Never"/>
