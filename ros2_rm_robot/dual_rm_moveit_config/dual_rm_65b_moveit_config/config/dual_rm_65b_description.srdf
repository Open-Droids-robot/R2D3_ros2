    <disable_collisions link1="right_thumb_distal" link2="right_index_proximal" reason="Never"/>
    <disable_collisions link1="right_thumb_distal" link2="right_index_intermediate" reason="Default"/>

    <!-- Right adjacent fingers -->
    <disable_collisions link1="right_index_proximal" link2="right_middle_proximal" reason="Never"/>
    <disable_collisions link1="right_index_proximal" link2="right_middle_intermediate" reason="Never"/>
    <disable_collisions link1="right_index_intermediate" link2="right_middle_proximal" reason="Never"/>
    <disable_collisions link1="right_index_intermediate" link2="right_middle_intermediate" reason="Default"/>
    <disable_collisions link1="right_middle_proximal" link2="right_ring_proximal" reason="Never"/>
