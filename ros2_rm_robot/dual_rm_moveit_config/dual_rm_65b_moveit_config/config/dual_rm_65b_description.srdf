    <!-- Right index chain -->
    <disable_collisions link1="right_index_proximal" link2="right_index_intermediate" reason="Adjacent"/>

    <!-- Right middle chain -->
    <disable_collisions link1="right_middle_proximal" link2="right_middle_intermediate" reason="Adjacent"/>

    <!-- Right ring chain -->
    <disable_collisions link1="right_ring_proximal" link2="right_ring_intermediate" reason="Adjacent"/>

    <!-- Right pinky chain -->
    <disable_collisions link1="right_pinky_proximal" link2="right_pinky_intermediate" reason="Adjacent"/>

    <!-- Right thumb with other fingers -->
    <disable_collisions link1="right_thumb_proximal_base" link2="right_index_proximal" reason="Never"/>
    <disable_collisions link1="right_thumb_proximal_base" link2="right_middle_proximal" reason="Never"/>
    <disable_collisions link1="right_thumb_proximal_base" link2="right_ring_proximal" reason="Never"/>
    <disable_collisions link1="right_thumb_proximal_base" link2="right_pinky_proximal" reason="Never"/>
    <disable_collisions link1="right_thumb_proximal" link2="right_index_proximal" reason="Never"/>
    <disable_collisions link1="right_thumb_proximal" link2="right_index_intermediate" reason="Default"/>
    <disable_collisions link1="right_thumb_proximal" link2="right_middle_proximal" reason="Never"/>
    <disable_collisions link1="right_thumb_proximal" link2="right_ring_proximal" reason="Never"/>
    <disable_collisions link1="right_thumb_proximal" link2="right_pinky_proximal" reason="Never"/>
