    <disable_collisions link1="right_hand_base_link" link2="right_pinky_intermediate" reason="Never"/>

    <!-- Right thumb chain -->
    <disable_collisions link1="right_thumb_proximal_base" link2="right_thumb_proximal" reason="Adjacent"/>
    <disable_collisions link1="right_thumb_proximal_base" link2="right_thumb_intermediate" reason="Never"/>
    <disable_collisions link1="right_thumb_proximal_base" link2="right_thumb_distal" reason="Never"/>
