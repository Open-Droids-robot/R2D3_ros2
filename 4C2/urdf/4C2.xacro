      <geometry>
        <mesh filename="file://$(find 4C2)/meshes/r_2.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}r_2_joint" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="${prefix}r_2_base" />
    <child link="${prefix}r_2" />
    <axis xyz="0 0 1" />
    <limit lower="0" upper="1" effort="1" velocity="0.3" />
    <dynamics damping="0.5" friction="0.05"/>
    <mimic joint="${prefix}gripper_joint" multiplier="1" offset="0" />
  </joint>

  <link name="${prefix}l_2_base">
    <inertial>
      <origin xyz="4.9960036108132E-16 6.48786580015326E-16 0.012531825941704" rpy="0 0 0" />
      <mass value="0.000523674592701011" />
      <inertia ixx="3.0734714815725E-08" ixy="-3.98073805558355E-27" ixz="-1.82481294203138E-23" iyy="3.0734714815725E-08" iyz="1.84719820823576E-24" izz="7.12500693959128E-10" />
