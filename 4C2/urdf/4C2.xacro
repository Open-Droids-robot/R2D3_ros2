      <geometry>
        <mesh filename="file://$(find 4C2)/meshes/l_2_base.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}l_2_base_joint" type="fixed">
    <origin xyz="-0.012574 -0.03 0.081" rpy="3.1416 -1.5708 0" />
    <parent link="${prefix}base_link" />
    <child link="${prefix}l_2_base" />
    <axis xyz="0 0 1" />
  </joint>

  <link name="${prefix}l_2">
    <inertial>
      <origin xyz="0.01758 -0.005679999999999999 0.01252" rpy="0 0 0" />
      <mass value="0.01199" />
      <inertia ixx="6.1843e-07" ixy="6.0251e-07" ixz="1.99e-09" iyy="2.2908200000000003e-06" iyz="-6.400000000000001e-10" izz="2.13501e-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
