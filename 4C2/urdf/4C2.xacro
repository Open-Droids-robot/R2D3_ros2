      <mass value="0.000523674592701008" />
      <inertia ixx="3.07347148157248E-08" ixy="2.19812746469581E-26" ixz="-1.61003603633463E-23" iyy="3.07347148157248E-08" iyz="-1.75942006429497E-23" izz="7.12500693959128E-10" />
