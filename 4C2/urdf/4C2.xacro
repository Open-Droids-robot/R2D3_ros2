      <geometry>
        <mesh filename="file://$(find 4C2)/meshes/r_1.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}gripper_joint" type="revolute">
    <origin xyz="-0.0125 0.04 0.079" rpy="3.1416 -1.5708 0" />
    <parent link="${prefix}base_link" />
    <child link="${prefix}r_1" />
    <axis xyz="0 0 1" />
    <limit lower="0" upper="0.865" effort="1" velocity="0.3" />
    <dynamics damping="0.5" friction="0.05"/>
  </joint>

  <link name="${prefix}r_3">
    <inertial>
      <origin xyz="0.00894 -0.01025 0.009" rpy="0 0 0" />
      <mass value="0.00967" />
      <inertia ixx="4.7741e-07" ixy="2.7354e-07" ixz="-0.0" iyy="1.01048e-06" iyz="-0.0" izz="1.13484e-06" />
