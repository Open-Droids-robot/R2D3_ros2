<?xml version="1.0" encoding="utf-8"?>
<robot name="4C2" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="gripper_4c2" params="prefix">
  
  <link name="${prefix}base_link">
