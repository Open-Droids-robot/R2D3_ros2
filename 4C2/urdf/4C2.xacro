    <parent link="${prefix}base_link" />
    <child link="${prefix}r_2_base" />
    <axis xyz="0 0 1" />
  </joint>

  <link name="${prefix}r_2">
    <inertial>
      <origin xyz="0.01758 0.005679999999999999 0.01248" rpy="0 0 0" />
      <mass value="0.01199" />
      <inertia ixx="6.1843e-07" ixy="-6.0251e-07" ixz="-1.99e-09" iyy="2.2908200000000003e-06" iyz="-6.400000000000001e-10" izz="2.13501e-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find 4C2)/meshes/r_2.STL" />
      </geometry>
      <material name="${prefix}dark_grey">
        <color rgba="0.25 0.25 0.25 1" />
