      </geometry>
      <material name="${prefix}dark_grey">
        <color rgba="0.25 0.25 0.25 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find 4C2)/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="${prefix}r_1">
