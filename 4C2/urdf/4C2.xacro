  </gazebo>
  <gazebo reference="${prefix}r_2_base">
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="${prefix}r_2">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="${prefix}r_3">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="${prefix}l_1">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="${prefix}l_2_base">
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="${prefix}l_2">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="${prefix}l_3">
    <material>Gazebo/Grey</material>
  </gazebo>

  <ros2_control name="${prefix}GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="${prefix}gripper_joint">
      <param name="pos_kp">5.0</param>
      <param name="pos_ki">0.0</param>
      <param name="pos_kd">0.1</param>
      <param name="pos_max_integral_error">1.0</param>
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="${prefix}r_3_joint">
      <command_interface name="position">
        <param name="min">0</param>
        <param name="max">1.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="${prefix}l_1_joint">
      <command_interface name="position">
        <param name="min">0</param>
        <param name="max">1.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="${prefix}l_3_joint">
      <command_interface name="position">
        <param name="min">0</param>
        <param name="max">1.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="${prefix}r_2_joint">
      <command_interface name="position">
        <param name="min">0</param>
        <param name="max">1.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="${prefix}l_2_joint">
      <command_interface name="position">
        <param name="min">0</param>
        <param name="max">1.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
  
  <gazebo>
    <plugin name="${prefix}mimic_r3" filename="libroboticsgroup_upatras_gazebo_mimic_joint_plugin.so">
      <joint>${prefix}gripper_joint</joint>
      <mimicJoint>${prefix}r_3_joint</mimicJoint>
      <multiplier>1.0</multiplier>
      <maxEffort>0.5</maxEffort>
    </plugin>
    <plugin name="${prefix}mimic_l1" filename="libroboticsgroup_upatras_gazebo_mimic_joint_plugin.so">
      <joint>${prefix}gripper_joint</joint>
      <mimicJoint>${prefix}l_1_joint</mimicJoint>
      <multiplier>1.0</multiplier>
      <maxEffort>0.5</maxEffort>
    </plugin>
    <plugin name="${prefix}mimic_l3" filename="libroboticsgroup_upatras_gazebo_mimic_joint_plugin.so">
      <joint>${prefix}gripper_joint</joint>
      <mimicJoint>${prefix}l_3_joint</mimicJoint>
      <multiplier>1.0</multiplier>
      <maxEffort>0.5</maxEffort>
    </plugin>
    <plugin name="${prefix}mimic_r2" filename="libroboticsgroup_upatras_gazebo_mimic_joint_plugin.so">
      <joint>${prefix}gripper_joint</joint>
      <mimicJoint>${prefix}r_2_joint</mimicJoint>
      <multiplier>1.0</multiplier>
      <maxEffort>0.5</maxEffort>
    </plugin>
    <plugin name="${prefix}mimic_l2" filename="libroboticsgroup_upatras_gazebo_mimic_joint_plugin.so">
      <joint>${prefix}gripper_joint</joint>
      <mimicJoint>${prefix}l_2_joint</mimicJoint>
      <multiplier>1.0</multiplier>
      <maxEffort>0.5</maxEffort>
    </plugin>
  </gazebo>
  
  </xacro:macro>
</robot>