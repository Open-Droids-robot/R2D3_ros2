    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find 4C2)/meshes/l_2.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}l_2_joint" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="${prefix}l_2_base" />
    <child link="${prefix}l_2" />
    <axis xyz="0 0 -1" />
    <limit lower="0" upper="1" effort="1" velocity="0.3" />
    <dynamics damping="0.5" friction="0.05"/>
    <mimic joint="${prefix}gripper_joint" multiplier="1" offset="0" />
  </joint>

  <gazebo reference="${prefix}gripper_joint">
    <implicitSpringDamper>true</implicitSpringDamper>
    <initialPosition>0.0</initialPosition>
  </gazebo>
  <gazebo reference="${prefix}r_3_joint">
    <implicitSpringDamper>true</implicitSpringDamper>
    <initialPosition>0.0</initialPosition>
  </gazebo>
  <gazebo reference="${prefix}l_1_joint">
    <implicitSpringDamper>true</implicitSpringDamper>
    <initialPosition>0.0</initialPosition>
  </gazebo>
  <gazebo reference="${prefix}l_3_joint">
    <implicitSpringDamper>true</implicitSpringDamper>
    <initialPosition>0.0</initialPosition>
  </gazebo>
  <gazebo reference="${prefix}r_2_joint">
