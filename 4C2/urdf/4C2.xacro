      <origin xyz="0.015880000000000002 0.00512 0.01252" rpy="0 0 0" />
      <mass value="0.00864" />
      <inertia ixx="6.1597e-07" ixy="-6.8471e-07" ixz="2.8500000000000003e-09" iyy="2.5165100000000002e-06" iyz="9.2e-10" izz="2.3915300000000003e-06" />
