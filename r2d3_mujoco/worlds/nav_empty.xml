<mujoco model="nav_world">

  <visual>
    <headlight diffuse="0.8 0.8 0.8" ambient="0.3 0.3 0.3" specular="0.2 0.2 0.2"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.75 0.75 0.75" rgb2="0.85 0.85 0.85" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"/>
  </asset>

  <worldbody>
    <light pos="0 0 10" dir="-0.5 0.1 -0.9" directional="true" castshadow="false"
           diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2"/>

    <!-- Ground plane; friction high enough for wheel traction (Gazebo used mu=100) -->
    <geom name="ground" type="plane" size="50 50 0.1" material="groundplane"
          friction="1.5 0.005 0.0001"/>

    <!-- Walls (10 x 0.2 x 1 m full size -> half-extents 5 0.1 0.5) -->
    <geom name="wall_north" type="box" size="5 0.1 0.5" pos="0 5 0.5"  rgba="0.5 0.5 0.5 1"/>
    <geom name="wall_south" type="box" size="5 0.1 0.5" pos="0 -5 0.5" rgba="0.5 0.5 0.5 1"/>
    <geom name="wall_east"  type="box" size="0.1 5 0.5" pos="5 0 0.5"  rgba="0.5 0.5 0.5 1"/>
    <geom name="wall_west"  type="box" size="0.1 5 0.5" pos="-5 0 0.5" rgba="0.5 0.5 0.5 1"/>

    <!-- Obstacles -->
    <geom name="box1" type="box" size="0.5 0.5 0.5"   pos="2 2 0.5"   rgba="0.8 0.2 0.2 1"/>
    <geom name="box2" type="box" size="0.4 0.75 0.5"  pos="-2 -1 0.5" rgba="0.2 0.2 0.8 1"/>
    <geom name="cylinder1" type="cylinder" size="0.4 0.5" pos="-1 3 0.5" rgba="0.2 0.8 0.2 1"/>
  </worldbody>

</mujoco>
